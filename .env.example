# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/learning-navigator

# Session Secret
SESSION_SECRET=your-super-secret-session-key-change-in-production

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Google Calendar API
GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=Learning Navigator <noreply@learningnavigator.com>

# Frontend URL (for CORS and redirects)
CLIENT_URL=http://localhost:3000

# Admin Email (the only email that can register as administrator)
ADMIN_EMAIL=trlandrew@students.highline.edu

# Allowed Email Domain for registration
ALLOWED_DOMAIN=students.highline.edu

# Test Accounts (only for development)
TEST_STUDENT_EMAIL_1=1411andrew@gmail.com
TEST_STUDENT_EMAIL_2=ev0ldave@gmail.com
TEST_ADMIN_EMAIL=trlandrew@students.highline.edu
