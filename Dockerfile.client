FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY client/package*.json ./

# Install dependencies
RUN npm install

# Copy client code
COPY client/ .

# Build for production
RUN npm run build

# Serve with a simple http server
RUN npm install -g serve

USER node

EXPOSE 3000

CMD ["serve", "-s", "build", "-l", "3000"]
